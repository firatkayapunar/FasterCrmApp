@model ModalInputViewModel

<div class="input-group input-group-outline my-3">
    <label class="form-label">Ad Soyad</label>
    <input id="name" type="text" class="form-control" @(Model.IsReadonly ? "readonly" : "")>
</div>
<div class="input-group input-group-outline my-3">
    <label class="form-label">E-posta</label>
    <input id="email" type="email" class="form-control" @(Model.IsReadonly ? "readonly" : "")>
</div>
<div class="form-check my-3">
    <input class="form-check-input" type="checkbox" id="islocked" @(Model.IsDisabled ? "disabled" : "")>
    <label class="custom-control-label" for="islocked">Pasif</label>
</div>
<div class="input-group input-group-outline is-filled my-3">
    <label for="role" class="form-label">Rolü</label>
    <select class="form-control" id="role" @(Model.IsDisabled ? "disabled" : "")>
        @{
            @foreach (var role in FasterCrmApp.Services.Concrete.RoleHelper.GetAllRoles())
            {
                <option value="@role.Key">@role.Value</option>
            }
        }
    </select>
</div>

@if (Model.HasID)
{
    <input type="hidden" id="userid" value="">
}
