                <p class="text-sm ">Aylık müşteri artış/ azalış grafiği</p>
                <div class="pe-2">
                    <div class="chart">
                        <canvas id="chart-line" class="chart-canvas" height="170"></canvas>
                    </div>
                </div>
                <hr class="dark horizontal">
                @* <div class="d-flex ">
