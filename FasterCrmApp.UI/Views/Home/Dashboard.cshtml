                </div> *@
            </div>
        </div>
    </div>
    <div class="col-lg-4 mt-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h6 class="mb-0 ">Aylık Tahsilat Analizi</h6>
                <p class="text-sm ">Aylık tahsilat artış/ azalış grafiği</p>
