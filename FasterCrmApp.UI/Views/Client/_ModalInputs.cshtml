@model ModalInputViewModel

<div class="input-group input-group-outline my-3">
    <label class="form-label">Ad Soyad / Şirket Adı</label>
    <input id="name" type="text" class="form-control" @(Model.IsReadonly ? "readonly" : "") autocomplete="off">
</div>
<div class="input-group input-group-outline my-3">
    <label class="form-label">E-Posta</label>
    <input id="email" type="email" class="form-control" @(Model.IsReadonly ? "readonly" : "") autocomplete="off">
</div>
<div class="input-group input-group-outline my-3">
    <label class="form-label">Telefon</label>
    <input id="phone" type="tel" class="form-control" @(Model.IsReadonly ? "readonly" : "") autocomplete="off">
</div>
<div class="form-check my-3">
    <input class="form-check-input" type="checkbox" id="iscorporate" @(Model.IsDisabled ? "disabled" : "")>
    <label class="custom-control-label" for="iscorporate">Kurumsal</label>
</div>
<div class="form-check my-3">
    <input class="form-check-input" type="checkbox" id="islocked" @(Model.IsDisabled ? "disabled" : "")>
    <label class="custom-control-label" for="islocked">Pasif</label>
</div>
<div class="input-group input-group-outline my-3">
    <label class="form-label">Açıklama</label>
    <textarea id="description" col="30" row="3" class="form-control" @(Model.IsReadonly ? "readonly" : "") autocomplete="off"></textarea>
</div>

@if(Model.HasID){
    <input type="hidden" id="clientid" value="" />
}
